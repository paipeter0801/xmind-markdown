---
import Layout from '../layouts/Layout.astro'
import Converter from '../components/converter/Converter.svelte'
---

<Layout title="AI GoEZ · XMind ⇄ Markdown 轉換器（免費・隱私・離線）">
  <div class="container mx-auto px-4 py-8 max-w-7xl">
    <!-- Hero Section -->
    <section class="text-center mb-12 animate-fade-in">
      <h1 class="text-5xl font-bold mb-4 bg-gradient-to-r from-primary-500 to-primary-700 bg-clip-text text-transparent">
        XMind ⇄ Markdown
      </h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
        <span class="font-semibold text-slate-800 dark:text-slate-200">免費・隱私・離線・XMind 8 相容</span>
        — 檔案不上傳，全程在你的瀏覽器完成。AI GoEZ 出品的雙向轉換器。
      </p>
    </section>

    <!-- Main Content -->
    <main class="animate-slide-up">
      <Converter client:load />
    </main>
  </div>
</Layout>
